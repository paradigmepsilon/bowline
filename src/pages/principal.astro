---
import BaseLayout from "../layouts/BaseLayout.astro";
import ImageHero from "../components/ImageHero.astro";
import Section from "../components/Section.astro";
import ImageBand from "../components/ImageBand.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Cta from "../components/Cta.astro";
import Panel from "../components/Panel.astro";
import { company, principal, display } from "../config/company";

const principalName = display(principal.name, null);
---

<BaseLayout
  title="Principal & Past Performance"
  description={`${company.dba} is a newly formed firm. Its past performance is represented by the individual professional experience of its principal - a service-disabled veteran with 20+ years of enterprise IT experience and an MBA.`}
  path="/principal"
>
  <ImageHero
    src="/hero-principal.jpg"
    imgAlt="Quiet executive workspace at dusk, twilight city beyond the glass"
    eyebrow="Principal & Past Performance"
    title="A new firm, led by an experienced practitioner"
  />

  <!-- New-entity disclosure + principal card -->
  <Section surface="mist">
    <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
      <div class="max-w-2xl" data-reveal>
        <Panel tone="light" accent="left">
          <p class="eyebrow text-signal">New Entity Disclosure</p>
          <p class="mt-3 text-lg leading-relaxed text-navy">
            {company.newEntityStatement}
          </p>
        </Panel>
        <p class="mt-8 text-base leading-relaxed text-steel-600">{principal.summary}</p>
        <p class="mt-4 text-base leading-relaxed text-steel-600">
          We do not represent corporate past performance the firm has not yet
          earned. What follows is the principal&rsquo;s individual professional
          experience - the foundation on which Bowline Federal is built.
        </p>
      </div>

      <aside data-reveal>
        <Panel tone="dark">
          <p class="eyebrow text-signal-bright">{principal.title}</p>
          {
            principalName && (
              <p class="mt-2 font-display text-xl font-600 text-mist-50">{principalName}</p>
            )
          }
          <dl class="mt-6 space-y-4 border-t border-steel-700/70 pt-6 text-sm">
            <div>
              <dt class="eyebrow text-steel-500">Service</dt>
              <dd class="mt-1.5 text-steel-200">Service-disabled U.S. military veteran</dd>
            </div>
            <div>
              <dt class="eyebrow text-steel-500">Experience</dt>
              <dd class="mt-1.5 text-steel-200">20+ years enterprise information technology</dd>
            </div>
            <div>
              <dt class="eyebrow text-steel-500">Education</dt>
              <dd class="mt-1.5 text-steel-200">Master of Business Administration</dd>
            </div>
          </dl>
        </Panel>
      </aside>
    </div>
  </Section>

  <!-- Individual experience -->
  <Section surface="navy-700">
    <SectionHeading
      eyebrow="Individual Experience"
      title="Two decades of enterprise IT practice"
      tone="dark"
      index="02"
    />
    <ul class="mt-10 grid gap-px overflow-hidden rounded border border-steel-700/70 bg-steel-700/70 sm:grid-cols-2" data-reveal-group>
      {
        principal.experience.map((item) => (
          <li class="flex gap-3 bg-navy-700 p-6" data-reveal>
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-signal" aria-hidden="true" />
            <span class="text-sm leading-relaxed text-steel-300">{item}</span>
          </li>
        ))
      }
    </ul>
    <p class="mt-8 max-w-2xl text-xs leading-relaxed text-steel-500" data-reveal>
      The above reflects the principal&rsquo;s individual career and is not a
      representation of contracts performed by Bowline Federal Technologies, LLC.
    </p>
  </Section>

  <!-- Judgment band -->
  <ImageBand
    src="/band-strategy.jpg"
    alt="Quiet strategy room at dusk with a glass wall of systems diagrams"
  />

  <!-- CTA -->
  <Section surface="navy">
    <div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center sm:justify-between" data-reveal>
      <h2 class="max-w-xl heading-2 text-mist-50">
        Want the principal&rsquo;s full background for an evaluation?
      </h2>
      <Cta href="/contact">Contact Bowline Federal</Cta>
    </div>
  </Section>
</BaseLayout>
