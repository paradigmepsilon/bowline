---
/**
 * Capability-statement request form. Submits via the visitor's own mail client
 * (mailto:) to the BFT contract inbox. No third-party backend or stored PII.
 * The browser composes a pre-addressed message; the visitor presses send.
 */
const contactInbox = "contract@bowlinefederal.com";

const field =
  "mt-2 w-full rounded border border-mist-200 bg-paper px-4 py-3 text-navy placeholder:text-steel-500 focus:border-signal focus:outline-none focus:ring-2 focus:ring-signal/30";
const label = "block text-sm font-500 text-navy";
---

<form
  action={`mailto:${contactInbox}?subject=${encodeURIComponent("Capability statement request - Bowline Federal")}`}
  method="post"
  enctype="text/plain"
  class="space-y-5 sm:space-y-6"
>
  <div>
    <label for="name" class={label}>Name <span class="text-signal">*</span></label>
    <input
      id="name"
      name="name"
      type="text"
      required
      autocomplete="name"
      class={field}
      placeholder="Full name"
    />
  </div>

  <div>
    <label for="organization" class={label}>
      Agency or company <span class="text-signal">*</span>
    </label>
    <input
      id="organization"
      name="organization"
      type="text"
      required
      autocomplete="organization"
      class={field}
      placeholder="Agency, office, or prime contractor"
    />
  </div>

  <div>
    <label for="email" class={label}>Email <span class="text-signal">*</span></label>
    <input
      id="email"
      name="email"
      type="email"
      required
      autocomplete="email"
      class={field}
      placeholder="name@agency.gov"
    />
  </div>

  <div>
    <label for="message" class={label}>Message <span class="text-signal">*</span></label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      class={field}
      placeholder="Describe your requirement, contract vehicle, or teaming interest."
    ></textarea>
  </div>

  <button
    type="submit"
    class="inline-flex min-h-11 items-center justify-center rounded bg-signal px-7 text-sm font-600 text-white transition-colors hover:bg-signal-bright active:translate-y-px"
  >
    Send request
  </button>
  <p class="text-xs text-steel-600">
    Fields marked with <span class="text-signal">*</span> are required. We use your
    information only to respond to your inquiry.
  </p>
</form>
