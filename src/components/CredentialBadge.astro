---
/**
 * One credential pill. Held = Signal-wash + signal text; in-progress = steel
 * ring + an honest "in progress" tag. Echoes the board's "FedRAMP-ready" pill,
 * truthfully (FedRAMP shows in-progress).
 */
interface Props {
  name: string;
  held: boolean;
  tone?: "light" | "dark";
}
const { name, held, tone = "light" } = Astro.props;

const base =
  "inline-flex items-center gap-2 rounded-full border px-3.5 py-1.5 text-sm";
const heldClass =
  "border-signal/40 bg-[var(--signal-wash)] text-signal" +
  (tone === "dark" ? "-bright" : "");
const progressClass =
  tone === "dark"
    ? "border-steel-700 text-steel-300"
    : "border-mist-200 text-steel-600";
---

<span class:list={[base, held ? heldClass : progressClass]}>
  <span class="font-500">{name}</span>
  {
    !held && (
      <span class="mono-data text-[0.65rem] uppercase tracking-wide opacity-80">
        in progress
      </span>
    )
  }
</span>
