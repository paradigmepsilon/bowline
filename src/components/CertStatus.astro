---
import { certifications, type CertStatus } from "../config/company";

/**
 * Set-aside certification stack with HONEST status labels. Nothing here reads
 * as "awarded" — every set-aside carries its true standing from config. The
 * "Held" pill is reserved for genuinely-held items (none of the set-asides).
 */
interface Props {
  tone?: "light" | "dark";
  class?: string;
}
const { tone = "dark", class: className } = Astro.props;

const statusStyles: Record<CertStatus, string> = {
  held: "text-signal-bright ring-signal/40 bg-[var(--signal-wash)]",
  "in-process": "text-steel-300 ring-steel-500/50 bg-steel-500/10",
  eligible: "text-steel-300 ring-steel-500/50 bg-steel-500/10",
};

const panel =
  tone === "dark"
    ? "border-steel-700/80 bg-steel-900/40"
    : "border-mist-200 bg-paper";
const titleColor = tone === "dark" ? "text-mist-50" : "text-navy";
const bodyColor = tone === "dark" ? "text-steel-400" : "text-steel-600";
const labelColor = tone === "dark" ? "text-steel-300" : "text-steel-600";
---

<ul class:list={["grid gap-3 sm:grid-cols-2", className]} data-reveal-group>
  {
    certifications.map((cert) => (
      <li class:list={["rounded border p-5", panel]} data-reveal>
        <div class="flex items-start justify-between gap-3">
          <span class:list={["font-display text-base font-600", titleColor]}>
            {cert.name}
          </span>
          <span
            class:list={[
              "shrink-0 rounded-full px-2.5 py-0.5 font-mono text-[0.65rem] uppercase tracking-wide ring-1",
              statusStyles[cert.status],
            ]}
          >
            {cert.status === "held" ? "Held" : "In process"}
          </span>
        </div>
        <p class:list={["mt-1.5 text-xs font-500", labelColor]}>{cert.statusLabel}</p>
        <p class:list={["mt-2 text-sm leading-relaxed", bodyColor]}>{cert.detail}</p>
      </li>
    ))
  }
</ul>
