---
/**
 * Restrained secure-core network - a small node cluster with one Signal-Blue
 * core. Reads as protected infrastructure, not a busy "AI mesh". ~7 nodes only.
 * Decorative (aria-hidden), inline SVG.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 320 320"
  fill="none"
  aria-hidden="true"
  preserveAspectRatio="xMidYMid meet"
>
  <!-- links -->
  <g stroke="var(--color-steel-700)" stroke-width="1.25">
    <line x1="160" y1="160" x2="70" y2="80"></line>
    <line x1="160" y1="160" x2="250" y2="90"></line>
    <line x1="160" y1="160" x2="60" y2="230"></line>
    <line x1="160" y1="160" x2="240" y2="240"></line>
    <line x1="160" y1="160" x2="160" y2="48"></line>
  </g>
  <!-- a faint protective ring around the core -->
  <circle cx="160" cy="160" r="30" stroke="var(--color-signal)" stroke-width="1" opacity="0.5"></circle>
  <!-- outer nodes -->
  <g fill="var(--color-steel-500)">
    <circle cx="70" cy="80" r="4"></circle>
    <circle cx="250" cy="90" r="4"></circle>
    <circle cx="60" cy="230" r="4"></circle>
    <circle cx="240" cy="240" r="4"></circle>
    <circle cx="160" cy="48" r="4"></circle>
  </g>
  <!-- the secure core -->
  <circle cx="160" cy="160" r="6.5" fill="var(--color-signal)"></circle>
</svg>
