---
/**
 * Bordered, flat container - the board's panel language. Not a floating card:
 * elevation is communicated by surface + a single hairline border, with an
 * optional single Signal-Blue accent edge.
 *
 * tone:   "light" (on mist) | "dark" (on navy)
 * accent: "left" | "top" | "none" - where the single signal edge sits
 */
interface Props {
  tone?: "light" | "dark";
  accent?: "left" | "top" | "none";
  class?: string;
}
const { tone = "light", accent = "none", class: className } = Astro.props;

const toneClass =
  tone === "dark"
    ? "border-steel-700/80 bg-steel-900/40"
    : "border-mist-200 bg-paper shadow-[0_1px_2px_rgba(20,36,58,0.06),0_1px_3px_rgba(20,36,58,0.04)]";

const accentClass = {
  left: "border-l-2 border-l-signal",
  top: "border-t-2 border-t-signal",
  none: "",
}[accent];
---

<div class:list={["rounded border p-5 sm:p-6 lg:p-8", toneClass, accentClass, className]}>
  <slot />
</div>
